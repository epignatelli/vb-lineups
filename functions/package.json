{
  "name": "vb-sessions-functions",
  "description": "Cloud Functions for VB Sessions",
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --testPathIgnorePatterns=rules",
