  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^9.0.1",
    "stripe": "^17.0.0"
  },
  "private": true,
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.15.0",
    "jest": "^29.7.0"
  }
}
